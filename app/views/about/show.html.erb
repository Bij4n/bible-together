<% content_for :title, t("home.about.heading") %>

<article class="landing space-y-16 py-2 sm:space-y-20 sm:py-4">
  <header class="max-w-2xl space-y-4">
    <p class="font-ui text-sm font-semibold uppercase tracking-[0.14em] text-accent-700">
      <%= t("app.name") %>
    </p>
    <h1 class="font-ui text-3xl font-semibold tracking-tight text-surface-900 sm:text-4xl">
      <%= t("home.about.heading") %>
    </h1>
    <p class="font-reading text-xl leading-relaxed text-surface-600">
      <%= t("home.about.subhead") %>
    </p>
  </header>

  <div class="max-w-3xl">
    <p class="font-reading text-lg leading-relaxed text-surface-700">
      <%= t("home.about.para_1") %>
    </p>
  </div>

  <section class="landing-bento-card max-w-3xl space-y-3" aria-labelledby="about-vision">
    <h2 id="about-vision" class="font-ui text-sm font-semibold uppercase tracking-wide text-surface-500">
      <%= t("home.about.vision_label") %>
    </h2>
    <p class="font-reading text-lg leading-relaxed text-surface-700">
      <%= t("home.about.para_vision") %>
    </p>
  </section>

  <figure class="landing-bento-card max-w-3xl border-l-4 border-accent-700/40 pl-6 sm:pl-8">
    <blockquote class="space-y-4 font-reading text-lg leading-relaxed text-surface-800">
      <p><%= t("home.about.para_2") %></p>
      <p><%= t("home.about.para_3") %></p>
    </blockquote>
  </figure>

  <section class="landing-bento-card max-w-3xl space-y-3" aria-labelledby="about-team">
    <h2 id="about-team" class="font-ui text-sm font-semibold uppercase tracking-wide text-surface-500">
      <%= t("home.about.team_label") %>
    </h2>
    <p class="font-reading text-lg leading-relaxed text-surface-700">
      <%= t("home.about.para_team") %>
    </p>
  </section>

  <div class="grid max-w-4xl gap-6 sm:grid-cols-2">
    <section class="landing-bento-card">
      <h2 class="font-ui text-sm font-semibold uppercase tracking-wide text-surface-500">
        <%= t("home.about.translations_label") %>
      </h2>
      <p class="mt-3 font-reading text-base leading-relaxed text-surface-700">
        <%= t("home.about.para_4") %>
      </p>
    </section>
    <section class="landing-bento-card">
      <h2 class="font-ui text-sm font-semibold uppercase tracking-wide text-surface-500">
        <%= t("home.about.support_label") %>
      </h2>
      <p class="mt-3 font-reading text-base leading-relaxed text-surface-700">
        <%= t("home.about.para_5") %>
      </p>
    </section>
  </div>

  <section class="landing-bento-card max-w-3xl space-y-3" aria-labelledby="about-nonprofit">
    <h2 id="about-nonprofit" class="font-ui text-sm font-semibold uppercase tracking-wide text-surface-500">
      <%= t("home.about.nonprofit_label") %>
    </h2>
    <p class="font-reading text-lg leading-relaxed text-surface-700">
      <%= t("home.about.para_nonprofit") %>
    </p>
  </section>

  <div class="flex flex-wrap items-center gap-x-5 gap-y-3">
    <%= link_to t("home.cta_public_bible"),
                public_bible_chapter_path(translation: "kjv", book: "gen", chapter: 1),
                class: "inline-flex items-center rounded-full bg-accent-700 px-6 py-3 font-ui text-base font-medium text-surface-50 transition-colors hover:bg-accent-800" %>
    <% if donate_link_visible? %>
      <%= link_to donate_path,
                  class: "inline-flex items-center gap-1.5 font-ui text-base font-medium text-surface-700 transition-colors hover:text-accent-700" do %>
        <%= t("layout.donate_link") %>
        <span aria-hidden="true">&rarr;</span>
      <% end %>
    <% end %>
  </div>
</article>
