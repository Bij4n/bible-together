<% content_for :title, t("home.about.heading") %>

<article class="mx-auto max-w-2xl space-y-14 sm:space-y-16">
  <header class="space-y-5">
    <p class="font-ui text-sm font-semibold uppercase tracking-[0.14em] text-accent-700">
      <%= t("app.name") %>
    </p>
    <h1 class="font-ui text-4xl font-semibold tracking-[-0.03em] text-surface-900 sm:text-5xl">
      <%= t("home.about.heading") %>
    </h1>
    <p class="font-reading text-xl leading-relaxed text-pretty text-surface-700">
      <%= t("home.about.subhead") %>
    </p>
    <p class="font-reading text-lg leading-relaxed text-pretty text-surface-600">
      <%= t("home.about.para_1") %>
    </p>
  </header>

  <%# The vision is the centerpiece — carried by type scale, not a box. %>
  <section class="space-y-4" aria-labelledby="about-vision">
    <p id="about-vision" class="font-ui text-xs font-semibold uppercase tracking-[0.14em] text-accent-700">
      <%= t("home.about.vision_label") %>
    </p>
    <p class="font-reading text-2xl leading-snug text-pretty text-surface-900 sm:text-[1.75rem] sm:leading-[1.35]">
      <%= t("home.about.para_vision") %>
    </p>
  </section>

  <section class="space-y-3 border-t border-surface-200 pt-10" aria-labelledby="about-team">
    <h2 id="about-team" class="font-ui text-sm font-semibold uppercase tracking-wide text-surface-500">
      <%= t("home.about.team_label") %>
    </h2>
    <p class="font-reading text-lg leading-relaxed text-pretty text-surface-700">
      <%= t("home.about.para_team") %>
    </p>
  </section>

  <section class="grid gap-x-10 gap-y-8 border-t border-surface-200 pt-10 sm:grid-cols-2">
    <div class="space-y-2">
      <h2 class="font-ui text-sm font-semibold uppercase tracking-wide text-surface-500">
        <%= t("home.about.nonprofit_label") %>
      </h2>
      <p class="font-reading text-base leading-relaxed text-surface-700">
        <%= t("home.about.para_nonprofit") %>
      </p>
    </div>
    <div class="space-y-2">
      <h2 class="font-ui text-sm font-semibold uppercase tracking-wide text-surface-500">
        <%= t("home.about.translations_label") %>
      </h2>
      <p class="font-reading text-base leading-relaxed text-surface-700">
        <%= t("home.about.para_4") %>
      </p>
    </div>
  </section>

  <div class="flex flex-wrap items-center gap-x-5 gap-y-3 border-t border-surface-200 pt-10">
    <%= link_to t("home.cta_public_bible"),
                public_bible_chapter_path(translation: "kjv", book: "gen", chapter: 1),
                class: "inline-flex items-center rounded-full bg-accent-700 px-6 py-3 font-ui text-base font-medium text-surface-50 transition-colors hover:bg-accent-800" %>
    <% if donate_link_visible? %>
      <%= link_to donate_path,
                  class: "inline-flex items-center gap-1.5 font-ui text-base font-medium text-surface-700 transition-colors hover:text-accent-700" do %>
        <%= t("layout.donate_link") %>
        <span aria-hidden="true">&rarr;</span>
      <% end %>
    <% end %>
  </div>
</article>
