<% content_for :title, @thread.title %>
<% is_admin = user_signed_in? && current_user.admin? %>
<%
  input = "w-full rounded-md border border-surface-300 bg-surface-50 px-3 py-2 font-ui text-sm text-surface-900 transition-colors placeholder:text-surface-500 focus:border-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-700/20"
  hide_btn = "rounded-md border border-red-500/40 px-2.5 py-1 font-ui text-xs font-medium text-red-700 transition-colors hover:bg-red-500 hover:text-surface-50"
%>

<article class="mx-auto max-w-3xl space-y-8">
  <header class="space-y-2 border-b border-surface-200 pb-6">
    <p class="font-ui text-xs uppercase tracking-wider text-surface-500">
      <%= link_to t("forum.title"), forum_threads_path, class: "transition-colors hover:text-accent-700" %>
    </p>
    <h1 class="font-ui text-3xl font-semibold tracking-tight text-surface-900 sm:text-4xl"><%= @thread.title %></h1>
    <p class="font-ui text-xs text-surface-500"><%= t("forum.started_by", name: @thread.user.author_name) %></p>
    <% if is_admin %>
      <%= button_to t("forum.hide"), hide_forum_thread_path(@thread), method: :patch, form_class: "mt-2 inline",
                    data: { turbo_confirm: t("forum.hide") + "?" }, class: hide_btn %>
    <% end %>
  </header>

  <ul class="space-y-4">
    <% @posts.each do |post| %>
      <li id="post_<%= post.id %>" class="rounded-2xl border border-surface-200 bg-surface-50 p-5 sm:p-6">
        <div class="flex items-center justify-between gap-3">
          <p class="font-ui text-sm font-medium text-surface-700">
            <%= link_to post.user.author_name, author_path(post.user), class: "transition-colors hover:text-accent-700" %>
          </p>
          <p class="font-ui text-xs text-surface-400"><%= l(post.created_at, format: :long) %></p>
        </div>
        <div class="mt-2 whitespace-pre-wrap font-reading leading-relaxed text-surface-900"><%= post.body %></div>
        <% if is_admin %>
          <%= button_to t("forum.hide"), hide_forum_thread_forum_post_path(@thread, post), method: :patch, form_class: "mt-3 inline", class: hide_btn %>
        <% end %>
      </li>
    <% end %>
  </ul>

  <% if user_signed_in? %>
    <section class="rounded-2xl border border-surface-200 bg-surface-50 p-5 sm:p-6">
      <h2 class="font-ui text-sm font-semibold uppercase tracking-wider text-surface-500"><%= t("forum.reply_heading") %></h2>
      <%= form_with url: forum_thread_forum_posts_path(@thread), method: :post, scope: :forum_post, class: "mt-3 space-y-3" do |f| %>
        <%= f.text_area :body, rows: 4, required: true, "aria-label": t("forum.reply_heading"), class: input %>
        <%= f.submit t("forum.reply"), class: "rounded-full bg-accent-700 px-5 py-2 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800" %>
      <% end %>
    </section>
  <% else %>
    <p class="font-ui text-sm text-surface-600">
      <%= link_to t("forum.sign_in_to_post"), new_user_session_path, class: "underline underline-offset-2 transition-colors hover:text-accent-700" %>
    </p>
  <% end %>
</article>
