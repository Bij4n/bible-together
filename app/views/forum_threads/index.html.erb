<% content_for :title, t("forum.title") %>
<% content_for :meta_description, t("forum.intro") %>

<article class="mx-auto max-w-3xl space-y-8">
  <header class="flex flex-wrap items-end justify-between gap-4 border-b border-surface-200 pb-6">
    <div class="space-y-2">
      <h1 class="font-ui text-4xl font-semibold tracking-tight text-surface-900 sm:text-5xl">
        <%= t("forum.title") %>
      </h1>
      <p class="font-reading text-surface-600"><%= t("forum.intro") %></p>
    </div>
    <% if user_signed_in? %>
      <%= link_to t("forum.new_thread"), new_forum_thread_path,
                  class: "shrink-0 rounded-full bg-accent-700 px-5 py-2.5 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800" %>
    <% else %>
      <%= link_to t("forum.sign_in_to_post"), new_user_session_path,
                  class: "shrink-0 font-ui text-sm font-medium text-accent-700 transition-colors hover:text-accent-800" %>
    <% end %>
  </header>

  <% if @threads.any? %>
    <ul class="space-y-3">
      <% @threads.each do |thread| %>
        <li class="rounded-2xl border border-surface-200 bg-surface-50 p-5 transition-colors hover:border-surface-300 sm:p-6">
          <%= link_to forum_thread_path(thread), class: "block" do %>
            <h2 class="font-ui text-lg font-semibold text-surface-900"><%= thread.title %></h2>
            <p class="mt-1 font-ui text-xs text-surface-500">
              <%= t("forum.started_by", name: thread.user.author_name) %>
              <span aria-hidden="true">·</span>
              <%= t("forum.replies", count: [ thread.forum_posts.count - 1, 0 ].max) %>
            </p>
          <% end %>
        </li>
      <% end %>
    </ul>
  <% else %>
    <p class="rounded-2xl border border-surface-200 bg-surface-100/60 px-8 py-12 text-center font-ui text-sm text-surface-600">
      <%= t("forum.no_threads") %>
    </p>
  <% end %>
</article>
