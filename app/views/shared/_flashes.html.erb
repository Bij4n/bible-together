<% flash.each do |key, message| %>
  <% alert = key.to_s == "alert" %>
  <div class="mb-6 rounded-md border px-4 py-3 font-ui text-sm <%= alert ? "border-red-200 bg-red-50 text-red-800" : "border-surface-200 bg-surface-100 text-surface-700" %>"
       role="<%= alert ? "alert" : "status" %>">
    <%= message %>
  </div>
<% end %>
