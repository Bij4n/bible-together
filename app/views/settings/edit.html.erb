<% content_for :title, t("settings.title") %>
<%
  # Each settings section renders as an Echo-style rounded-2xl card —
  # same chrome vocabulary as homepage feature cards + Devise auth
  # shell. The cards give the page visual containment that the prior
  # bare-stack layout lacked; preferences read as discrete settings
  # rather than a wall of forms.
  section_card   = "block rounded-2xl border border-surface-200 bg-surface-50 p-6 sm:p-8"
  section_h2     = "font-ui text-lg font-semibold tracking-tight text-surface-900"
  section_p      = "mt-1.5 font-ui text-sm text-surface-600"
  label_classes  = "flex items-center gap-2 font-ui text-sm text-surface-700"
  radio_classes  = "h-4 w-4 accent-accent-700"
  input_classes  = "w-full rounded-md border border-surface-300 bg-surface-50 px-3 py-2 font-ui text-sm text-surface-900 transition-colors placeholder:text-surface-500 focus:border-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-700/20"
  submit_classes = "rounded-full bg-accent-700 px-4 py-1.5 font-ui text-xs font-medium text-surface-50 transition-colors hover:bg-accent-800"
%>

<article class="mx-auto max-w-2xl space-y-10">
  <header class="space-y-2 border-b border-surface-200 pb-6">
    <p class="font-ui text-xs font-medium uppercase tracking-wider text-surface-500">
      <%= current_user.email %>
    </p>
    <h1 class="font-ui text-4xl font-semibold tracking-tight text-surface-900 sm:text-5xl">
      <%= t("settings.title") %>
    </h1>
    <p class="max-w-2xl pt-1 font-ui text-base leading-relaxed text-pretty text-surface-600">
      <%= t("settings.description") %>
    </p>
  </header>

  <div class="space-y-6">
    <%# ----------  Language  ---------- %>
    <%= turbo_frame_tag "settings_language", class: "#{section_card} space-y-4" do %>
      <div>
        <h2 class="<%= section_h2 %>"><%= t("settings.sections.language.title") %></h2>
        <p class="<%= section_p %>"><%= t("settings.sections.language.description") %></p>
      </div>
      <%= form_with model: current_user, url: settings_path, method: :patch, data: { turbo_frame: "settings_language", controller: "preference-form" }, class: "space-y-3" do |f| %>
        <div class="flex flex-col gap-2">
          <% User::UI_LOCALES.each do |code| %>
            <label class="<%= label_classes %>">
              <%= f.radio_button :ui_locale, code, data: { action: "change->preference-form#submit" }, class: radio_classes %>
              <%= t("layout.language_#{code}") %>
            </label>
          <% end %>
        </div>
        <noscript>
          <%= f.submit t("settings.save"), class: submit_classes %>
        </noscript>
      <% end %>
      <%= render "shared/settings_flash" %>
    <% end %>

    <%# ----------  Default translation  ---------- %>
    <%= turbo_frame_tag "settings_default_translation", class: "#{section_card} space-y-4" do %>
      <div>
        <h2 class="<%= section_h2 %>"><%= t("settings.sections.default_translation.title") %></h2>
        <p class="<%= section_p %>"><%= t("settings.sections.default_translation.description") %></p>
      </div>
      <%= form_with model: current_user, url: settings_path, method: :patch, data: { turbo_frame: "settings_default_translation", controller: "preference-form" }, class: "space-y-3" do |f| %>
        <%= f.select :default_translation_id,
                     Translation.order(:name).pluck(:name, :id),
                     { include_blank: t("settings.sections.default_translation.none") },
                     data: { action: "change->preference-form#submit" },
                     "aria-label": t("settings.sections.default_translation.title"),
                     class: "#{input_classes} [&>option]:bg-surface-50 [&>option]:text-surface-900" %>
        <noscript>
          <%= f.submit t("settings.save"), class: submit_classes %>
        </noscript>
      <% end %>
      <%= render "shared/settings_flash" %>
    <% end %>

    <%# ----------  Display name  ---------- %>
    <%= turbo_frame_tag "settings_display_name", class: "#{section_card} space-y-4" do %>
      <div>
        <h2 class="<%= section_h2 %>"><%= t("settings.sections.display_name.title") %></h2>
        <p class="<%= section_p %>"><%= t("settings.sections.display_name.description") %></p>
      </div>
      <%= form_with model: current_user, url: settings_path, method: :patch, data: { turbo_frame: "settings_display_name" }, class: "flex items-end gap-3" do |f| %>
        <div class="flex-1">
          <%= f.text_field :display_name,
                           maxlength: User::DISPLAY_NAME_MAX,
                           "aria-label": t("settings.sections.display_name.title"),
                           class: input_classes %>
        </div>
        <%= f.submit t("settings.save"), class: submit_classes %>
      <% end %>
      <%= render "shared/settings_flash" %>
    <% end %>

    <%# ----------  Username  ---------- %>
    <%= turbo_frame_tag "settings_username", class: "#{section_card} space-y-4" do %>
      <div>
        <h2 class="<%= section_h2 %>"><%= t("settings.sections.username.title") %></h2>
        <p class="<%= section_p %>"><%= t("settings.sections.username.description") %></p>
      </div>
      <%= form_with model: current_user, url: settings_path, method: :patch, data: { turbo_frame: "settings_username" }, class: "flex items-end gap-3" do |f| %>
        <div class="flex-1">
          <%= f.text_field :username,
                           "aria-label": t("settings.sections.username.title"),
                           placeholder: t("settings.sections.username.placeholder"),
                           class: input_classes %>
        </div>
        <%= f.submit t("settings.save"), class: submit_classes %>
      <% end %>
      <%= render "shared/settings_flash" %>
    <% end %>

    <%# ----------  Bio  ---------- %>
    <%= turbo_frame_tag "settings_bio", class: "#{section_card} space-y-4" do %>
      <div>
        <h2 class="<%= section_h2 %>"><%= t("settings.sections.bio.title") %></h2>
        <p class="<%= section_p %>"><%= t("settings.sections.bio.description") %></p>
      </div>
      <%= form_with model: current_user, url: settings_path, method: :patch, data: { turbo_frame: "settings_bio" }, class: "space-y-3" do |f| %>
        <%= f.text_area :bio, rows: 3, maxlength: User::BIO_MAX, "aria-label": t("settings.sections.bio.title"), class: input_classes %>
        <%= f.submit t("settings.save"), class: submit_classes %>
      <% end %>
      <%= render "shared/settings_flash" %>
    <% end %>

    <%# ----------  Notifications  ---------- %>
    <%= turbo_frame_tag "settings_notifications", class: "#{section_card} space-y-4" do %>
      <div>
        <h2 class="<%= section_h2 %>"><%= t("settings.sections.notifications.title") %></h2>
        <p class="<%= section_p %>"><%= t("settings.sections.notifications.description") %></p>
      </div>
      <%= form_with model: current_user, url: settings_path, method: :patch, data: { turbo_frame: "settings_notifications", controller: "preference-form" }, class: "space-y-3" do |f| %>
        <label class="<%= label_classes %>">
          <%= f.check_box :email_on_comment, data: { action: "change->preference-form#submit" }, class: "h-4 w-4 rounded accent-accent-700" %>
          <%= t("settings.sections.notifications.email_on_comment") %>
        </label>
        <noscript>
          <%= f.submit t("settings.save"), class: submit_classes %>
        </noscript>
      <% end %>
      <%= render "shared/settings_flash" %>
    <% end %>
  </div>
</article>
