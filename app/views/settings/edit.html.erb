<% content_for :title, t("settings.title") %>
<%
  # Editorial settings: each preference is a divided section (thin rule +
  # generous spacing) rather than a boxed card, matching the About/How-it-
  # works language. turbo-frame needs `block` to lay out as a section.
  section_wrap   = "block border-t border-surface-200 pt-8 space-y-4"
  section_h2     = "font-ui text-base font-semibold text-surface-900"
  section_p      = "mt-1 font-reading text-sm leading-relaxed text-surface-600"
  label_classes  = "flex items-center gap-2 font-ui text-sm text-surface-700"
  radio_classes  = "h-4 w-4 accent-accent-700"
  input_classes  = "w-full rounded-md border border-surface-300 bg-surface-50 px-3 py-2 font-ui text-sm text-surface-900 transition-colors placeholder:text-surface-500 focus:border-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-700/20"
  submit_classes = "shrink-0 rounded-full bg-accent-700 px-4 py-2 font-ui text-xs font-medium text-surface-50 transition-colors hover:bg-accent-800"
%>

<article class="mx-auto max-w-2xl space-y-10">
  <header class="space-y-3">
    <h1 class="font-ui text-4xl font-semibold tracking-[-0.03em] text-surface-900 sm:text-5xl">
      <%= t("settings.title") %>
    </h1>
    <p class="font-reading text-lg leading-relaxed text-pretty text-surface-600">
      <%= t("settings.description") %>
    </p>
    <p class="font-ui text-sm text-surface-500">
      <%= t("auth.signed_in_as", email: current_user.email) %>
    </p>
  </header>

  <div class="space-y-8">
    <%# ----------  Language  ---------- %>
    <%= turbo_frame_tag "settings_language", class: section_wrap do %>
      <div>
        <h2 class="<%= section_h2 %>"><%= t("settings.sections.language.title") %></h2>
        <p class="<%= section_p %>"><%= t("settings.sections.language.description") %></p>
      </div>
      <%= form_with model: current_user, url: settings_path, method: :patch, data: { turbo_frame: "settings_language", controller: "preference-form" }, class: "space-y-3" do |f| %>
        <div class="flex flex-col gap-2">
          <% User::UI_LOCALES.each do |code| %>
            <label class="<%= label_classes %>">
              <%= f.radio_button :ui_locale, code, data: { action: "change->preference-form#submit" }, class: radio_classes %>
              <%= t("layout.language_#{code}") %>
            </label>
          <% end %>
        </div>
        <noscript>
          <%= f.submit t("settings.save"), class: submit_classes %>
        </noscript>
      <% end %>
      <%= render "shared/settings_flash" %>
    <% end %>

    <%# ----------  Default translation  ---------- %>
    <%= turbo_frame_tag "settings_default_translation", class: section_wrap do %>
      <div>
        <h2 class="<%= section_h2 %>"><%= t("settings.sections.default_translation.title") %></h2>
        <p class="<%= section_p %>"><%= t("settings.sections.default_translation.description") %></p>
      </div>
      <%= form_with model: current_user, url: settings_path, method: :patch, data: { turbo_frame: "settings_default_translation", controller: "preference-form" }, class: "space-y-3" do |f| %>
        <%= f.select :default_translation_id,
                     Translation.order(:name).pluck(:name, :id),
                     { include_blank: t("settings.sections.default_translation.none") },
                     data: { action: "change->preference-form#submit" },
                     "aria-label": t("settings.sections.default_translation.title"),
                     class: "#{input_classes} [&>option]:bg-surface-50 [&>option]:text-surface-900" %>
        <noscript>
          <%= f.submit t("settings.save"), class: submit_classes %>
        </noscript>
      <% end %>
      <%= render "shared/settings_flash" %>
    <% end %>

    <%# ----------  Display name  ---------- %>
    <%= turbo_frame_tag "settings_display_name", class: section_wrap do %>
      <div>
        <h2 class="<%= section_h2 %>"><%= t("settings.sections.display_name.title") %></h2>
        <p class="<%= section_p %>"><%= t("settings.sections.display_name.description") %></p>
      </div>
      <%= form_with model: current_user, url: settings_path, method: :patch, data: { turbo_frame: "settings_display_name" }, class: "flex items-end gap-3" do |f| %>
        <div class="flex-1">
          <%= f.text_field :display_name,
                           maxlength: User::DISPLAY_NAME_MAX,
                           "aria-label": t("settings.sections.display_name.title"),
                           class: input_classes %>
        </div>
        <%= f.submit t("settings.save"), class: submit_classes %>
      <% end %>
      <%= render "shared/settings_flash" %>
    <% end %>

    <%# ----------  Username  ---------- %>
    <%= turbo_frame_tag "settings_username", class: section_wrap do %>
      <div>
        <h2 class="<%= section_h2 %>"><%= t("settings.sections.username.title") %></h2>
        <p class="<%= section_p %>"><%= t("settings.sections.username.description") %></p>
      </div>
      <%= form_with model: current_user, url: settings_path, method: :patch, data: { turbo_frame: "settings_username" }, class: "flex items-end gap-3" do |f| %>
        <div class="flex-1">
          <%= f.text_field :username,
                           "aria-label": t("settings.sections.username.title"),
                           placeholder: t("settings.sections.username.placeholder"),
                           class: input_classes %>
        </div>
        <%= f.submit t("settings.save"), class: submit_classes %>
      <% end %>
      <%= render "shared/settings_flash" %>
    <% end %>

    <%# ----------  Profile photo  ---------- %>
    <%= turbo_frame_tag "settings_avatar", class: section_wrap do %>
      <div>
        <h2 class="<%= section_h2 %>"><%= t("settings.sections.avatar.title") %></h2>
        <p class="<%= section_p %>"><%= t("settings.sections.avatar.description") %></p>
      </div>
      <%= form_with model: current_user, url: settings_path, method: :patch,
                    html: { multipart: true },
                    data: { turbo_frame: "settings_avatar" },
                    class: "flex flex-col gap-4 sm:flex-row sm:items-center" do |f| %>
        <%= user_avatar(current_user, size: :lg) %>
        <div class="flex-1 space-y-3">
          <%= f.file_field :avatar, accept: "image/png,image/jpeg,image/webp",
                           class: "block w-full font-ui text-sm text-surface-700 file:mr-3 file:rounded-full file:border-0 file:bg-surface-200 file:px-4 file:py-2 file:font-ui file:text-sm file:font-medium file:text-surface-800" %>
          <%= f.submit t("settings.save"), class: submit_classes %>
        </div>
      <% end %>
      <%= render "shared/settings_flash" %>
    <% end %>

    <%# ----------  Bio  ---------- %>
    <%= turbo_frame_tag "settings_bio", class: section_wrap do %>
      <div>
        <h2 class="<%= section_h2 %>"><%= t("settings.sections.bio.title") %></h2>
        <p class="<%= section_p %>"><%= t("settings.sections.bio.description") %></p>
      </div>
      <%= form_with model: current_user, url: settings_path, method: :patch, data: { turbo_frame: "settings_bio" }, class: "space-y-3" do |f| %>
        <%= f.text_area :bio, rows: 3, maxlength: User::BIO_MAX, "aria-label": t("settings.sections.bio.title"), class: input_classes %>
        <%= f.submit t("settings.save"), class: submit_classes %>
      <% end %>
      <%= render "shared/settings_flash" %>
    <% end %>

    <%# ----------  Highlight toolbar  ---------- %>
    <%= turbo_frame_tag "settings_highlights", class: section_wrap do %>
      <div>
        <h2 class="<%= section_h2 %>"><%= t("settings.sections.highlights.title") %></h2>
        <p class="<%= section_p %>"><%= t("settings.sections.highlights.description") %></p>
      </div>
      <%= form_with model: current_user, url: settings_path, method: :patch,
                    data: { turbo_frame: "settings_highlights" },
                    class: "space-y-6" do |f| %>
        <fieldset>
          <legend class="mb-3 font-ui text-xs font-medium uppercase tracking-widest text-surface-500">
            <%= t("settings.sections.highlights.toolbar_colors") %>
          </legend>
          <div class="grid gap-3 sm:grid-cols-2">
            <% Highlight::DEFAULT_TOOLBAR_COLORS.each do |color| %>
              <div class="flex items-center gap-3 rounded-lg border border-surface-200 bg-surface-50 px-3 py-2">
                <span class="h-5 w-5 shrink-0 rounded-full highlight-swatch-<%= color %>" aria-hidden="true"></span>
                <label class="flex min-w-0 flex-1 items-center gap-2 font-ui text-sm text-surface-700">
                  <%= check_box_tag "user[highlight_toolbar_colors][]", color,
                                    current_user.toolbar_colors.include?(color),
                                    id: "toolbar_color_#{color}",
                                    class: "h-4 w-4 accent-accent-700" %>
                  <%= t("highlights.colors.#{color}", default: color.capitalize) %>
                </label>
                <%= text_field_tag "user[highlight_color_labels][#{color}]",
                                   current_user.highlight_color_labels[color],
                                   placeholder: t("settings.sections.highlights.label_placeholder"),
                                   maxlength: 40,
                                   autocomplete: "off",
                                   class: "#{input_classes} max-w-[9rem] text-xs" %>
              </div>
            <% end %>
          </div>
        </fieldset>

        <fieldset>
          <legend class="mb-3 font-ui text-xs font-medium uppercase tracking-widest text-surface-500">
            <%= t("settings.sections.highlights.default_note_color") %>
          </legend>
          <div class="flex flex-wrap gap-3">
            <% Note::NOTE_COLORS.each do |color| %>
              <label class="flex cursor-pointer items-center gap-2 rounded-full border border-surface-200 px-3 py-1.5 font-ui text-sm text-surface-700 hover:bg-surface-100">
                <%= f.radio_button :default_note_color, color, class: radio_classes %>
                <span class="h-4 w-4 rounded-full note-marker-swatch-<%= color %>" aria-hidden="true"></span>
                <%= t("notes.colors.#{color}", default: color.capitalize) %>
              </label>
            <% end %>
          </div>
        </fieldset>

        <%= f.submit t("settings.save"), class: submit_classes %>
      <% end %>
      <%= render "shared/settings_flash" %>
    <% end %>

    <%# ----------  Notifications  ---------- %>
    <%= turbo_frame_tag "settings_notifications", class: section_wrap do %>
      <div>
        <h2 class="<%= section_h2 %>"><%= t("settings.sections.notifications.title") %></h2>
        <p class="<%= section_p %>"><%= t("settings.sections.notifications.description") %></p>
      </div>
      <%= form_with model: current_user, url: settings_path, method: :patch, data: { turbo_frame: "settings_notifications", controller: "preference-form" }, class: "space-y-3" do |f| %>
        <label class="<%= label_classes %>">
          <%= f.check_box :email_on_comment, data: { action: "change->preference-form#submit" }, class: "h-4 w-4 rounded accent-accent-700" %>
          <%= t("settings.sections.notifications.email_on_comment") %>
        </label>
        <noscript>
          <%= f.submit t("settings.save"), class: submit_classes %>
        </noscript>
      <% end %>
      <%= render "shared/settings_flash" %>
    <% end %>
  </div>
</article>
