<li id="<%= dom_id(note) %>"
    data-controller="<%= user_signed_in? ? "upvote flag" : "" %>"
    data-upvote-note-id-value="<%= note.id %>"
    data-upvote-upvoted-value="<%= note.upvoted_by?(current_user) %>"
    data-flag-note-id-value="<%= note.id %>"
    data-flag-prompt-value="<%= t("public_bible.flag_reason_prompt") %>"
    data-flag-success-value="<%= t("public_bible.flag_submitted") %>"
    data-flag-failure-value="<%= t("public_bible.flag_failed") %>"
    class="rounded border <%= note.featured? ? "border-gilt-500/50" : "border-walnut-900/15" %> bg-parchment-50 p-4 dark:border-gilt-500/30 dark:bg-walnut-800 <%= "ring-1 ring-gilt-500/40" if note.featured? %> <%= "opacity-60" if note.hidden? %>">
  <header class="flex items-start justify-between gap-3">
    <div>
      <p class="text-xs uppercase tracking-[0.18em] text-walnut-700/70 dark:text-amber-200/60">
        <%= note.highlights.map(&:osis_ref).join(", ") %>
        <span class="ml-2 italic normal-case tracking-normal">
          <%= t("public_bible.by_author", name: note.user.author_name) %>
        </span>
      </p>
      <% if note.featured? %>
        <span class="mt-1 inline-block rounded bg-gilt-500/15 px-2 py-0.5 text-xs font-display uppercase tracking-wider text-gilt-500 dark:text-gilt-400">
          ★ <%= t("public_bible.featured") %>
        </span>
      <% end %>
      <% if note.hidden? %>
        <span class="mt-1 inline-block rounded bg-rubric-500/15 px-2 py-0.5 text-xs font-display uppercase tracking-wider text-rubric-600">
          <%= t("public_bible.hidden") %>
        </span>
      <% end %>
    </div>

    <div class="flex items-center gap-2 text-xs">
      <% if user_signed_in? %>
        <button type="button"
                data-upvote-target="button"
                data-action="upvote#toggle"
                class="rounded border border-walnut-900/25 px-2 py-1 hover:border-walnut-900 dark:border-gilt-500/40 dark:hover:border-gilt-400 <%= "bg-walnut-900 text-parchment-100 dark:bg-amber-200 dark:text-walnut-900" if note.upvoted_by?(current_user) %>">
          <span>&#9650;</span>
          <span data-upvote-target="count"><%= note.upvote_count %></span>
        </button>
        <button type="button"
                data-action="flag#prompt"
                class="text-walnut-700 hover:text-rubric-500 dark:text-amber-300 dark:hover:text-gilt-400"
                title="<%= t("public_bible.flag") %>">
          <%= t("public_bible.flag") %>
        </button>
      <% else %>
        <span class="inline-flex items-center gap-1 text-walnut-700 dark:text-amber-300">
          <span>&#9650;</span>
          <span><%= note.upvote_count %></span>
        </span>
      <% end %>
    </div>
  </header>

  <div class="trix-content mt-2 font-serif text-walnut-900 dark:text-amber-200">
    <%= note.body %>
  </div>

  <%= render partial: "comments/thread", locals: { note: note } %>
</li>
