<% content_for :title, local_assigns[:heading] %>
<% subhead = local_assigns[:subhead] %>

<div class="mx-auto w-full max-w-md py-8 sm:py-12">
  <div class="rounded-2xl border border-surface-200 bg-surface-50 p-8 shadow-sm">
    <header class="mb-6 space-y-2 text-center">
      <h1 class="font-ui text-2xl font-semibold tracking-tight text-surface-900">
        <%= local_assigns[:heading] %>
      </h1>
      <% if subhead.present? %>
        <p class="font-reading text-sm leading-relaxed text-pretty text-surface-600">
          <%= subhead %>
        </p>
      <% end %>
    </header>
    <%= yield %>
  </div>
</div>
