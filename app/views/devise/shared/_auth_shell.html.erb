<% content_for :title, local_assigns[:heading] %>

<div class="mx-auto w-full max-w-md py-8">
  <div class="rounded-2xl border border-surface-200 bg-surface-50 p-8 shadow-sm">
    <h1 class="mb-6 text-center font-ui text-2xl font-semibold tracking-tight text-surface-900">
      <%= local_assigns[:heading] %>
    </h1>
    <%= yield %>
  </div>
</div>
