<section id="community" class="landing-section">
  <div class="mb-7 flex flex-wrap items-end justify-between gap-3">
    <div class="space-y-1.5">
      <h2 class="font-ui text-2xl font-semibold tracking-tight text-surface-900">
        <%= t("home.community.heading") %>
      </h2>
      <p class="font-reading text-base text-surface-600">
        <%= t("home.community.intro") %>
      </p>
    </div>
    <%= link_to community_path,
                class: "inline-flex items-center gap-1.5 font-ui text-sm font-medium text-accent-700 transition-colors hover:text-accent-800" do %>
      <%= t("layout.community_link") %>
      <span aria-hidden="true">&rarr;</span>
    <% end %>
  </div>

  <ul class="grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
    <% @community_entries.each do |note, verse| %>
      <li class="h-full">
        <%= render "community_note_card", note: note, verse: verse %>
      </li>
    <% end %>
  </ul>
</section>
