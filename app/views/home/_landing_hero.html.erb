<section class="landing-hero grid items-center gap-12 pt-4 lg:grid-cols-[1.05fr_0.95fr] lg:gap-16 lg:pt-8">
  <div class="relative z-10 max-w-xl space-y-7">
    <p class="font-ui text-sm font-semibold uppercase tracking-[0.14em] text-accent-700">
      <%= t("app.name") %>
    </p>

    <h1 class="font-ui text-[clamp(2.5rem,5.5vw,3.75rem)] font-semibold leading-[1.05] tracking-[-0.04em] text-surface-900">
      <%= t("home.welcome") %>
    </h1>

    <p class="font-reading text-xl leading-[1.55] text-pretty text-surface-600">
      <%= t("home.subhead") %>
    </p>

    <div class="flex flex-wrap items-center gap-x-5 gap-y-3 pt-1">
      <%= link_to t("home.cta_public_bible"),
                  public_bible_chapter_path(translation: "kjv", book: "gen", chapter: 1),
                  class: "inline-flex items-center rounded-full bg-accent-700 px-7 py-3.5 font-ui text-base font-medium text-surface-50 shadow-sm transition-colors hover:bg-accent-800" %>
      <%= link_to how_it_works_path,
                  class: "inline-flex items-center gap-1.5 font-ui text-base font-medium text-surface-700 transition-colors hover:text-accent-700" do %>
        <%= t("home.cta_how_it_works") %>
        <span aria-hidden="true">&rarr;</span>
      <% end %>
    </div>
  </div>

  <div class="relative z-10">
    <%= render "landing_preview" %>
  </div>
</section>
