<div class="landing max-w-2xl space-y-12 py-2 sm:py-4">
  <header class="space-y-4">
    <h1 class="font-ui text-3xl font-semibold tracking-tight text-surface-900 sm:text-4xl">
      <%= t("home.how_it_works_title") %>
    </h1>
    <p class="font-reading text-lg leading-relaxed text-surface-600">
      <%= t("home.landing.how_page_intro") %>
    </p>
  </header>

  <section aria-labelledby="how-steps-heading">
    <h2 id="how-steps-heading" class="font-ui text-sm font-semibold uppercase tracking-wide text-surface-500">
      <%= t("home.how.heading") %>
    </h2>
    <ol class="mt-4 space-y-6">
      <% (1..3).each do |n| %>
        <li>
          <h3 class="font-ui text-base font-semibold text-surface-900">
            <%= t("home.how.step_#{n}_title") %>
          </h3>
          <p class="mt-1 font-reading text-base leading-relaxed text-surface-600">
            <%= t("home.how.step_#{n}_body") %>
          </p>
        </li>
      <% end %>
    </ol>
  </section>

  <section aria-labelledby="how-features-heading">
    <h2 id="how-features-heading" class="font-ui text-sm font-semibold uppercase tracking-wide text-surface-500">
      <%= t("home.landing.features_label") %>
    </h2>
    <ul class="mt-4 space-y-2 font-reading text-base leading-relaxed text-surface-700">
      <% t("home.landing.feature_list").each do |item| %>
        <li class="flex gap-3">
          <span class="mt-2 h-1.5 w-1.5 shrink-0 rounded-full bg-surface-400" aria-hidden="true"></span>
          <span><%= item %></span>
        </li>
      <% end %>
    </ul>
  </section>

  <p>
    <%= link_to t("home.cta_public_bible"),
                public_bible_chapter_path(translation: "kjv", book: "gen", chapter: 1),
                class: "inline-flex items-center rounded-full bg-accent-700 px-6 py-3 font-ui text-base font-medium text-surface-50 transition-colors hover:bg-accent-800" %>
  </p>
</div>
