<article class="landing mx-auto max-w-2xl space-y-14 sm:space-y-16">
  <header class="space-y-5">
    <p class="font-ui text-sm font-semibold uppercase tracking-[0.14em] text-accent-700">
      <%= t("home.how_it_works_title") %>
    </p>
    <h1 class="font-ui text-4xl font-semibold tracking-[-0.03em] text-surface-900 sm:text-5xl">
      <%= t("home.landing.how_page_intro") %>
    </h1>
  </header>

  <section class="space-y-8" aria-labelledby="how-steps-heading">
    <h2 id="how-steps-heading" class="font-ui text-sm font-semibold uppercase tracking-wide text-surface-500">
      <%= t("home.how.heading") %>
    </h2>
    <ol class="space-y-8">
      <% (1..3).each do |n| %>
        <li class="flex gap-5">
          <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-accent-700/10 font-ui text-sm font-semibold text-accent-700" aria-hidden="true">
            <%= n %>
          </span>
          <div class="space-y-1.5 pt-1">
            <h3 class="font-ui text-lg font-semibold text-surface-900">
              <%= t("home.how.step_#{n}_title") %>
            </h3>
            <p class="font-reading text-base leading-relaxed text-pretty text-surface-600">
              <%= t("home.how.step_#{n}_body") %>
            </p>
          </div>
        </li>
      <% end %>
    </ol>
  </section>

  <section class="space-y-4 border-t border-surface-200 pt-10" aria-labelledby="how-features-heading">
    <h2 id="how-features-heading" class="font-ui text-sm font-semibold uppercase tracking-wide text-surface-500">
      <%= t("home.landing.features_label") %>
    </h2>
    <ul class="space-y-2.5 font-reading text-base leading-relaxed text-surface-700">
      <% t("home.landing.feature_list").each do |item| %>
        <li class="flex gap-3">
          <span class="mt-2.5 h-1.5 w-1.5 shrink-0 rounded-full bg-accent-700" aria-hidden="true"></span>
          <span><%= item %></span>
        </li>
      <% end %>
    </ul>
  </section>

  <div class="flex flex-wrap items-center gap-x-5 gap-y-3 border-t border-surface-200 pt-10">
    <%= link_to t("home.cta_public_bible"),
                public_bible_chapter_path(translation: "kjv", book: "gen", chapter: 1),
                class: "inline-flex items-center rounded-full bg-accent-700 px-6 py-3 font-ui text-base font-medium text-surface-50 transition-colors hover:bg-accent-800" %>
    <%= link_to about_path,
                class: "inline-flex items-center gap-1.5 font-ui text-base font-medium text-surface-700 transition-colors hover:text-accent-700" do %>
      <%= t("layout.about_link") %>
      <span aria-hidden="true">&rarr;</span>
    <% end %>
  </div>
</article>
