<div class="dashboard space-y-10">
  <header class="space-y-2">
    <h1 class="font-ui text-3xl font-semibold tracking-tight text-surface-900 sm:text-4xl">
      <%= t("home.dashboard.heading") %>
    </h1>
    <p class="font-reading text-base text-surface-600">
      <%= t("home.dashboard.subhead") %>
    </p>
  </header>

  <section class="rounded-2xl border border-surface-200 bg-surface-50 p-6 sm:p-8" aria-labelledby="continue-reading-heading">
    <h2 id="continue-reading-heading" class="font-ui text-sm font-semibold uppercase tracking-wide text-surface-500">
      <%= t("home.dashboard.continue_heading") %>
    </h2>
    <div class="mt-4 flex flex-wrap items-center justify-between gap-4">
      <p class="font-ui text-2xl font-semibold text-surface-900">
        <%= @continue_reading[:label] %>
      </p>
      <%= link_to t("home.dashboard.continue_cta"), @continue_reading[:path],
          class: "inline-flex items-center rounded-full bg-accent-700 px-5 py-2.5 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800" %>
    </div>
  </section>

  <div class="grid gap-8 lg:grid-cols-2">
    <section class="space-y-4" aria-labelledby="recent-notes-heading">
      <div class="flex items-center justify-between gap-3">
        <h2 id="recent-notes-heading" class="font-ui text-lg font-semibold text-surface-900">
          <%= t("home.dashboard.recent_notes_heading") %>
        </h2>
        <%= link_to t("home.dashboard.view_all_notes"), notes_path,
            class: "font-ui text-sm font-medium text-accent-700 transition-colors hover:text-accent-800" %>
      </div>
      <% if @recent_notes.any? %>
        <ul class="space-y-2">
          <% @recent_notes.each do |note| %>
            <li>
              <%= link_to note_path(note),
                  class: "block rounded-xl border border-surface-200 bg-surface-50 px-4 py-3 transition-colors hover:border-surface-300 hover:bg-surface-100" do %>
                <p class="font-ui text-sm font-medium text-surface-900 line-clamp-1">
                  <%= note.body.to_plain_text.truncate(80) %>
                </p>
                <p class="mt-1 font-ui text-xs text-surface-500">
                  <%= l(note.updated_at, format: :short) %>
                </p>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="font-reading text-sm text-surface-600"><%= t("home.dashboard.no_notes") %></p>
      <% end %>
    </section>

    <section class="space-y-4" aria-labelledby="active-studies-heading">
      <div class="flex items-center justify-between gap-3">
        <h2 id="active-studies-heading" class="font-ui text-lg font-semibold text-surface-900">
          <%= t("home.dashboard.studies_heading") %>
        </h2>
        <%= link_to t("home.dashboard.view_all_studies"), groups_path,
            class: "font-ui text-sm font-medium text-accent-700 transition-colors hover:text-accent-800" %>
      </div>
      <% if @active_studies.any? %>
        <ul class="space-y-2">
          <% @active_studies.each do |group| %>
            <li>
              <%= link_to group_path(group),
                  class: "block rounded-xl border border-surface-200 bg-surface-50 px-4 py-3 transition-colors hover:border-surface-300 hover:bg-surface-100" do %>
                <p class="font-ui text-sm font-medium text-surface-900"><%= group.name %></p>
                <% if group.description.present? %>
                  <p class="mt-1 font-reading text-xs text-surface-600 line-clamp-2"><%= group.description %></p>
                <% end %>
              <% end %>
            </li>
          <% end %>
        </ul>
      <% else %>
        <p class="font-reading text-sm text-surface-600"><%= t("home.dashboard.no_studies") %></p>
        <%= link_to t("home.dashboard.create_study"), new_group_path,
            class: "inline-flex items-center rounded-full border border-surface-300 px-4 py-2 font-ui text-sm font-medium text-surface-700 transition-colors hover:border-surface-400 hover:bg-surface-100" %>
      <% end %>
    </section>
  </div>
</div>
