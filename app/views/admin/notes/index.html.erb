<% content_for :title, t("admin.notes.title") %>
<%
  nav_link       = "transition-colors hover:text-accent-700"
  nav_link_active = "text-accent-700 underline underline-offset-4 decoration-accent-700"
  neutral_sm_btn = "rounded-full border border-surface-300 bg-transparent px-2.5 py-0.5 font-ui text-xs font-medium text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900"
  danger_sm_btn  = "rounded-md border border-red-500/40 bg-transparent px-2.5 py-0.5 font-ui text-xs font-medium text-red-700 transition-colors hover:bg-red-500 hover:text-surface-50"
%>

<article class="mx-auto max-w-5xl space-y-6">
  <header class="space-y-2 border-b border-surface-200 pb-6">
    <p class="font-ui text-xs font-medium uppercase tracking-wider text-surface-500">
      <%= t("admin.title") %>
    </p>
    <h1 class="font-ui text-3xl font-semibold tracking-tight text-surface-900 sm:text-4xl">
      <%= t("admin.notes.title") %>
    </h1>
  </header>

  <nav class="flex items-center gap-4 font-ui text-sm text-surface-700">
    <% [ %w[all All], %w[flagged Flagged], %w[featured Featured], %w[hidden Hidden] ].each do |filter, _| %>
      <% active = @filter == filter || (filter == "all" && @filter.blank?) %>
      <%= link_to t("admin.filters.#{filter}"),
                  admin_notes_path(filter: (filter == "all" ? nil : filter)),
                  class: active ? nav_link_active : nav_link %>
    <% end %>
    <span aria-hidden="true" class="text-surface-300">·</span>
    <%= link_to t("admin.nav.flags"), admin_flags_path, class: nav_link %>
  </nav>

  <% if @notes.any? %>
    <table class="w-full table-auto border-collapse font-ui text-sm">
      <thead class="border-b border-surface-200 text-left text-xs font-semibold uppercase tracking-wider text-surface-500">
        <tr>
          <th class="py-2 pr-3"><%= t("admin.notes.header_author") %></th>
          <th class="py-2 pr-3"><%= t("admin.notes.header_preview") %></th>
          <th class="py-2 pr-3 text-center"><%= t("admin.notes.header_upvotes") %></th>
          <th class="py-2 pr-3 text-center"><%= t("admin.notes.header_flags") %></th>
          <th class="py-2 pr-3"><%= t("admin.notes.header_status") %></th>
          <th class="py-2 pr-3 text-right"><%= t("admin.notes.header_actions") %></th>
        </tr>
      </thead>
      <tbody class="divide-y divide-surface-200 text-surface-900">
        <% @notes.each do |note| %>
          <tr class="<%= "bg-red-500/5" if note.flags.unresolved.any? %>">
            <td class="py-2 pr-3"><%= note.user.author_name %></td>
            <td class="py-2 pr-3 max-w-md truncate"><%= truncate(note.body.to_plain_text, length: 100) %></td>
            <td class="py-2 pr-3 text-center"><%= note.upvote_count %></td>
            <td class="py-2 pr-3 text-center"><%= note.flags.unresolved.size %></td>
            <td class="py-2 pr-3 space-x-1 text-xs">
              <% if note.featured? %>
                <span class="rounded-full bg-accent-700/10 px-2.5 py-0.5 font-medium tracking-wide text-accent-700"><%= t("public_bible.featured") %></span>
              <% end %>
              <% if note.hidden? %>
                <span class="rounded-full bg-red-500/10 px-2.5 py-0.5 font-medium tracking-wide text-red-700"><%= t("public_bible.hidden") %></span>
              <% end %>
            </td>
            <td class="py-2 pr-0 text-right space-x-1">
              <% if note.featured? %>
                <%= button_to t("admin.notes.unfeature"), unfeature_admin_note_path(note), method: :patch, form_class: "inline", class: neutral_sm_btn %>
              <% else %>
                <%= button_to t("admin.notes.feature"), feature_admin_note_path(note), method: :patch, form_class: "inline", class: neutral_sm_btn %>
              <% end %>
              <% if note.hidden? %>
                <%= button_to t("admin.notes.unhide"), unhide_admin_note_path(note), method: :patch, form_class: "inline", class: neutral_sm_btn %>
              <% else %>
                <%= button_to t("admin.notes.hide"), hide_admin_note_path(note), method: :patch, form_class: "inline",
                              data: { turbo_confirm: t("admin.notes.hide") + "?" },
                              class: danger_sm_btn %>
              <% end %>
            </td>
          </tr>
        <% end %>
      </tbody>
    </table>
  <% else %>
    <p class="font-ui text-sm text-surface-600"><%= t("admin.notes.empty") %></p>
  <% end %>
</article>
