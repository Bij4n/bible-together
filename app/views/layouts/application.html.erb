<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <% page_title = content_for?(:title) ? "#{content_for(:title)} · #{t("app.name")}" : t("app.name") %>
    <% page_description = content_for?(:meta_description) ? content_for(:meta_description) : t("app.meta_description") %>
    <% canonical_url = request.original_url.split("?").first %>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("app.name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= page_description %>">

    <%# Open Graph + Twitter card meta — used by Facebook, LinkedIn,
        Slack, iMessage, Twitter, etc. when a URL is shared. og:image
        falls back to /icon.png (the 512x512 brand glyph) since we
        don't ship a per-page social-card image yet. twitter:card =
        "summary" renders the small square card variant which fits
        the icon's aspect ratio; upgrade to "summary_large_image"
        once a 1200×630 social card asset is generated. %>
    <meta property="og:site_name" content="<%= t("app.name") %>">
    <meta property="og:title" content="<%= page_title %>">
    <meta property="og:description" content="<%= page_description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta property="og:image" content="<%= request.base_url %>/icon.png">
    <meta property="og:locale" content="<%= I18n.locale == :es ? "es_ES" : "en_US" %>">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_description %>">
    <meta name="twitter:image" content="<%= request.base_url %>/icon.png">

    <link rel="canonical" href="<%= canonical_url %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Self-hosted fonts live in /public/fonts and are loaded via
        @font-face rules in application.css. No Google Fonts or other
        third-party hosts — see CLAUDE.md. %>
    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/SourceSerif4Variable.woff2" as="font" type="font/woff2" crossorigin>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen antialiased pb-[calc(3.5rem+env(safe-area-inset-bottom))] sm:pb-0<%= " marketing-surface" if marketing_page? %>">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:rounded focus:bg-surface-900 focus:px-3 focus:py-1 focus:text-surface-50 font-ui">
      <%= t("layout.skip_to_content") %>
    </a>

    <%= render "layouts/header" %>

    <main id="main" class="mx-auto <%= layout_container_class %> px-6 py-12">
      <div id="flash_container">
        <%= render "shared/flashes" %>
      </div>
      <%= render "shared/locale_banner" %>
      <%= yield %>
    </main>

    <%= render "layouts/footer" %>
    <%= render "layouts/mobile_tab_bar" %>

    <%# Note editor slide-in. Echo card chrome: at sm+ the panel is a
        fixed-width card from the right edge with rounded-l corners
        (reads as "sliding card" rather than "screen plane"); at <sm
        the panel is full-width edge-to-edge so rounding the corners
        would clip awkwardly. shadow-2xl gives the elevation in light
        mode. In dark mode both panel bg and page bg are surface-950,
        so shadow alone leaves the edge invisible — the explicit
        + gives the panel a
        readable edge against the page. The note_panel_controller.js
        slide-in transform mechanic is untouched. %>
    <aside id="note-panel-container"
           class="fixed inset-y-0 right-0 w-full max-w-full translate-x-full transform bg-surface-50 shadow-2xl transition-transform duration-150 ease-out sm:max-w-md sm:rounded-l-2xl"
           aria-label="Note editor">
      <div class="h-full overflow-y-auto p-5 sm:p-6">
        <%= turbo_frame_tag "note_panel" %>
      </div>
    </aside>
  </body>
</html>
