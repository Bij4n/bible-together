<!DOCTYPE html>
<html lang="<%= I18n.locale %>">
  <head>
    <% page_title = content_for?(:title) ? "#{content_for(:title)} · #{t("app.name")}" : t("app.name") %>
    <% page_description = content_for?(:meta_description) ? content_for(:meta_description) : t("app.meta_description") %>
    <% canonical_url = request.original_url.split("?").first %>
    <title><%= page_title %></title>
    <meta name="viewport" content="width=device-width,initial-scale=1">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="application-name" content="<%= t("app.name") %>">
    <meta name="mobile-web-app-capable" content="yes">
    <meta name="description" content="<%= page_description %>">

    <%# Open Graph + Twitter card meta — used by Facebook, LinkedIn,
        Slack, iMessage, Twitter, etc. when a URL is shared. og:image
        falls back to /icon.png (the 512x512 brand glyph) since we
        don't ship a per-page social-card image yet. twitter:card =
        "summary" renders the small square card variant which fits
        the icon's aspect ratio; upgrade to "summary_large_image"
        once a 1200×630 social card asset is generated. %>
    <meta property="og:site_name" content="<%= t("app.name") %>">
    <meta property="og:title" content="<%= page_title %>">
    <meta property="og:description" content="<%= page_description %>">
    <meta property="og:type" content="website">
    <meta property="og:url" content="<%= canonical_url %>">
    <meta property="og:image" content="<%= request.base_url %>/icon.png">
    <meta property="og:locale" content="<%= I18n.locale == :es ? "es_ES" : "en_US" %>">
    <meta name="twitter:card" content="summary">
    <meta name="twitter:title" content="<%= page_title %>">
    <meta name="twitter:description" content="<%= page_description %>">
    <meta name="twitter:image" content="<%= request.base_url %>/icon.png">

    <link rel="canonical" href="<%= canonical_url %>">

    <%= csrf_meta_tags %>
    <%= csp_meta_tag %>

    <%= yield :head %>

    <%# Self-hosted fonts live in /public/fonts and are loaded via
        @font-face rules in application.css. No Google Fonts or other
        third-party hosts — see CLAUDE.md. %>
    <link rel="preload" href="/fonts/InterVariable.woff2" as="font" type="font/woff2" crossorigin>
    <link rel="preload" href="/fonts/SourceSerif4Variable.woff2" as="font" type="font/woff2" crossorigin>

    <link rel="icon" href="/icon.png" type="image/png">
    <link rel="icon" href="/icon.svg" type="image/svg+xml">
    <link rel="apple-touch-icon" href="/icon.png">

    <%= stylesheet_link_tag :app, "data-turbo-track": "reload" %>
    <%= javascript_importmap_tags %>
  </head>

  <body class="min-h-screen antialiased<%= " marketing-surface" if marketing_page? %>">
    <a href="#main" class="sr-only focus:not-sr-only focus:absolute focus:top-2 focus:left-2 focus:rounded focus:bg-surface-900 focus:px-3 focus:py-1 focus:text-surface-50 font-ui">
      <%= t("layout.skip_to_content") %>
    </a>

    <header class="site-header" data-controller="site-header">
      <div class="site-header__inner mx-auto flex <%= layout_container_class %> items-center justify-between gap-4 px-6 py-3.5">
        <%= render "shared/wordmark", class: "text-lg" %>

        <% rail_idle   = "site-nav-link hidden sm:inline-flex items-center rounded-full px-3.5 py-1.5 transition-colors hover:bg-surface-100 hover:text-surface-900" %>
        <% rail_active = "site-nav-link--active bg-surface-100 text-accent-800" %>
        <% rail_rest   = "text-surface-700" %>
        <% menu_item_base   = "block rounded-lg px-4 py-2.5 transition-colors hover:bg-surface-100 hover:text-surface-900" %>
        <% menu_item_idle   = "text-surface-700" %>
        <% menu_item_active = "bg-surface-100 text-accent-800" %>

        <nav class="site-nav flex items-center gap-1 font-ui text-sm" aria-label="<%= t("layout.main_nav") %>">
          <%= link_to t("layout.read_link"), bible_entry_path,
                      class: "#{rail_idle} #{request.path.start_with?("/bible") ? rail_active : rail_rest}" %>
          <% if user_signed_in? %>
            <%= link_to t("layout.studies_link"), groups_path,
                        class: "#{rail_idle} #{request.path.start_with?("/studies") ? rail_active : rail_rest}" %>
          <% end %>
          <%= link_to t("layout.community_link"), community_path,
                      class: "#{rail_idle} #{request.path.start_with?("/community") ? rail_active : rail_rest}" %>
          <% unless user_signed_in? %>
            <%= link_to t("layout.how_it_works_link"), how_it_works_path,
                        class: "#{rail_idle} #{nav_active?(how_it_works_path) ? rail_active : rail_rest}" %>
          <% end %>

          <%= link_to search_path,
                      class: "site-nav-link hidden sm:inline-flex items-center rounded-full px-3.5 py-1.5 transition-colors hover:bg-surface-100 hover:text-surface-900 #{nav_active?(search_path) ? rail_active : rail_rest}" do %>
            <%= t("search.submit") %>
          <% end %>

          <div data-controller="user-menu" class="relative">
            <button type="button"
                    data-user-menu-target="trigger"
                    data-action="user-menu#toggle"
                    aria-expanded="false"
                    aria-haspopup="true"
                    aria-label="<%= t("layout.open_menu") %>"
                    class="site-nav-menu-trigger flex items-center gap-1.5 rounded-full border border-surface-200 px-3 py-1.5 text-surface-700 transition-colors hover:border-surface-300 hover:bg-surface-100 hover:text-surface-900">
              <svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 20 20" fill="currentColor" class="h-5 w-5" aria-hidden="true">
                <path fill-rule="evenodd" d="M18 5.25a.75.75 0 0 1-.75.75H2.75a.75.75 0 0 1 0-1.5h14.5a.75.75 0 0 1 .75.75ZM18 10a.75.75 0 0 1-.75.75H2.75a.75.75 0 0 1 0-1.5h14.5A.75.75 0 0 1 18 10Zm0 4.75a.75.75 0 0 1-.75.75H2.75a.75.75 0 0 1 0-1.5h14.5a.75.75 0 0 1 .75.75Z" clip-rule="evenodd" />
              </svg>
              <span class="hidden sm:inline"><%= t("layout.account") %></span>
            </button>

            <div data-user-menu-target="menu"
                 hidden
                 role="menu"
                 aria-label="<%= t("layout.open_menu") %>"
                 class="account-sheet">

              <%# Mobile: full primary nav mirrors the desktop rail + Search. %>
              <div class="sm:hidden" role="none">
                <p class="account-sheet__label px-4 py-2 font-ui text-[10px] font-semibold uppercase tracking-[0.14em] text-surface-500">
                  <%= t("layout.nav_section") %>
                </p>
                <%= link_to t("layout.read_link"), bible_entry_path, role: "menuitem",
                            class: "#{menu_item_base} #{request.path.start_with?("/bible") ? menu_item_active : menu_item_idle}" %>
                <% if user_signed_in? %>
                  <%= link_to t("layout.studies_link"), groups_path, role: "menuitem",
                              class: "#{menu_item_base} #{request.path.start_with?("/studies") ? menu_item_active : menu_item_idle}" %>
                <% end %>
                <%= link_to t("layout.community_link"), community_path, role: "menuitem",
                            class: "#{menu_item_base} #{request.path.start_with?("/community") ? menu_item_active : menu_item_idle}" %>
                <% unless user_signed_in? %>
                  <%= link_to t("layout.how_it_works_link"), how_it_works_path, role: "menuitem",
                              class: "#{menu_item_base} #{nav_active?(how_it_works_path) ? menu_item_active : menu_item_idle}" %>
                <% end %>
                <%= link_to t("search.submit"), search_path, role: "menuitem",
                            class: "#{menu_item_base} #{nav_active?(search_path) ? menu_item_active : menu_item_idle}" %>
              </div>

              <div class="my-1 border-t border-surface-200 sm:hidden" role="separator"></div>

              <% if user_signed_in? %>
                <p class="account-sheet__label px-4 py-2 font-ui text-[10px] font-semibold uppercase tracking-[0.14em] text-surface-500">
                  <%= t("layout.account_section") %>
                </p>
                <div class="px-4 pb-1 font-ui text-xs text-surface-500">
                  <%= current_user.email %>
                </div>
                <%= link_to t("layout.my_notes_link"), notes_path, role: "menuitem", class: "#{menu_item_base} #{nav_active?(notes_path) ? menu_item_active : menu_item_idle}" %>
                <% if current_user.admin? %>
                  <%= link_to admin_notes_path, role: "menuitem", class: "#{menu_item_base} #{request.path.start_with?("/admin") ? menu_item_active : menu_item_idle}" do %><%= t("admin.title") %><% end %>
                <% end %>
                <%= link_to settings_path, role: "menuitem", class: "#{menu_item_base} #{nav_active?(settings_path) ? menu_item_active : menu_item_idle}" do %><%= t("auth.settings") %><% end %>
              <% else %>
                <%= link_to new_user_session_path, role: "menuitem", class: "#{menu_item_base} #{nav_active?(new_user_session_path) ? menu_item_active : menu_item_idle}" do %><%= t("auth.sign_in") %><% end %>
              <% end %>

              <% if user_signed_in? %>
                <div class="my-1 border-t border-surface-200" role="separator"></div>
                <%= button_to t("auth.sign_out"), destroy_user_session_path, method: :delete, form_class: "block", class: "block w-full rounded-lg px-4 py-2.5 text-left text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900" %>
              <% end %>
            </div>
          </div>
        </nav>
      </div>
    </header>

    <main id="main" class="mx-auto <%= layout_container_class %> px-6 py-12">
      <div id="flash_container">
        <%= render "shared/flashes" %>
      </div>
      <%= render "shared/locale_banner" %>
      <%= yield %>
    </main>

    <%
      footer_link_base   = "site-footer-link transition-colors hover:text-accent-700"
      footer_link_active = "site-footer-link--active text-accent-800"
    %>
    <footer class="site-footer border-t border-surface-200 bg-surface-100">
      <div class="mx-auto <%= layout_container_class %> space-y-8 px-6 py-10 sm:py-12">
        <div class="grid gap-8 sm:grid-cols-[minmax(0,1fr)_auto] sm:items-start sm:justify-between">
          <div class="max-w-sm space-y-2">
            <%= render "shared/wordmark", class: "text-base" %>
            <p class="font-reading text-sm leading-relaxed text-surface-600">
              <%= t("layout.footer_tagline") %>
            </p>
          </div>

          <nav class="site-footer-nav grid grid-cols-2 gap-x-10 gap-y-2 font-ui text-sm text-surface-600" aria-label="<%= t("layout.main_nav") %>">
            <% if donate_link_visible? %>
              <%= link_to t("layout.donate_link"), donate_path, class: "#{footer_link_base} #{footer_link_active if nav_active?(donate_path)}" %>
            <% end %>
            <%= link_to t("layout.how_it_works_link"), how_it_works_path, class: "#{footer_link_base} #{footer_link_active if nav_active?(how_it_works_path)}" %>
            <%= link_to t("layout.about_link"), about_path, class: "#{footer_link_base} #{footer_link_active if nav_active?(about_path)}" %>
            <%= link_to t("legal.terms.title"), terms_path, class: "#{footer_link_base} #{footer_link_active if nav_active?(terms_path)}" %>
            <%= link_to t("legal.privacy.title"), privacy_path, class: "#{footer_link_base} #{footer_link_active if nav_active?(privacy_path)}" %>
          </nav>
        </div>

        <div class="flex flex-col gap-4 border-t border-surface-200 pt-6 sm:flex-row sm:items-end sm:justify-between">
          <div class="space-y-1">
            <p class="font-ui text-xs text-balance text-surface-500">
              <%= t("layout.footer_attribution_translations") %>
            </p>
            <p class="font-ui text-[10px] uppercase tracking-widest text-surface-500">
              <%= t("layout.footer_attribution_meta", year: Date.current.year) %>
            </p>
          </div>

          <div class="flex gap-1" aria-label="<%= t("layout.language_switcher") %>">
            <% User::UI_LOCALES.each do |code| %>
              <% active = I18n.locale.to_s == code %>
              <% locale_classes = "rounded-full px-2.5 py-1 font-ui text-[10px] uppercase tracking-widest transition-colors #{active ? "bg-surface-200 text-surface-900" : "text-surface-500 hover:bg-surface-200/70 hover:text-surface-700"}" %>
              <% if user_signed_in? %>
                <%= button_to code.upcase, settings_path, method: :patch, params: { user: { ui_locale: code } }, form_class: "inline", class: locale_classes, aria: { label: t("layout.language_#{code}"), current: active ? "true" : nil } %>
              <% else %>
                <%= link_to code.upcase, url_for(locale: code), class: locale_classes, data: { turbo_prefetch: "false" }, aria: { label: t("layout.language_#{code}"), current: active ? "true" : nil } %>
              <% end %>
            <% end %>
          </div>
        </div>
      </div>
    </footer>

    <%# Note editor slide-in. Echo card chrome: at sm+ the panel is a
        fixed-width card from the right edge with rounded-l corners
        (reads as "sliding card" rather than "screen plane"); at <sm
        the panel is full-width edge-to-edge so rounding the corners
        would clip awkwardly. shadow-2xl gives the elevation in light
        mode. In dark mode both panel bg and page bg are surface-950,
        so shadow alone leaves the edge invisible — the explicit
        + gives the panel a
        readable edge against the page. The note_panel_controller.js
        slide-in transform mechanic is untouched. %>
    <aside id="note-panel-container"
           class="fixed inset-y-0 right-0 w-full max-w-full translate-x-full transform bg-surface-50 shadow-2xl transition-transform duration-150 ease-out sm:max-w-md sm:rounded-l-2xl"
           aria-label="Note editor">
      <div class="h-full overflow-y-auto p-5 sm:p-6">
        <%= turbo_frame_tag "note_panel" %>
      </div>
    </aside>
  </body>
</html>
