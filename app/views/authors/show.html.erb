<% content_for :title, @author.author_name %>
<% stats = profile_note_stats(@author, viewer: current_user) %>
<% is_owner = user_signed_in? && current_user == @author %>

<article class="mx-auto max-w-2xl space-y-14 sm:space-y-16">
  <header class="space-y-8">
    <div class="flex flex-col items-center gap-6 text-center sm:flex-row sm:items-start sm:text-left">
      <div class="shrink-0">
        <%= user_avatar(@author, size: :xl, extra_classes: "ring-4 ring-surface-100 shadow-sm") %>
      </div>
      <div class="min-w-0 flex-1 space-y-4">
        <% if @author.username.present? %>
          <p class="font-ui text-sm font-semibold uppercase tracking-[0.14em] text-accent-700">
            @<%= @author.username %>
          </p>
        <% end %>
        <div class="flex flex-col items-center gap-4 sm:flex-row sm:items-start sm:justify-between">
          <h1 class="font-ui text-4xl font-semibold tracking-[-0.03em] text-surface-900 sm:text-5xl">
            <%= @author.author_name %>
          </h1>
          <% if user_signed_in? && !is_owner %>
            <% if current_user.following?(@author) %>
              <%= button_to t("authors.unfollow"), author_follow_path(@author), method: :delete,
                            class: "shrink-0 rounded-full border border-surface-300 px-5 py-2.5 font-ui text-sm font-medium text-surface-700 transition-colors hover:bg-surface-100" %>
            <% else %>
              <%= button_to t("authors.follow"), author_follow_path(@author), method: :post,
                            class: "shrink-0 rounded-full bg-accent-700 px-5 py-2.5 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800" %>
            <% end %>
          <% end %>
        </div>
        <p class="font-ui text-sm text-surface-600">
          <%= t("authors.member_since", year: @author.created_at.year) %>
          <span aria-hidden="true"> · </span>
          <%= t("authors.followers", count: @author.followers.count) %>
          <span aria-hidden="true"> · </span>
          <%= t("authors.following_count", count: @author.following.count) %>
          <% if user_signed_in? && !is_owner && current_user.friends_with?(@author) %>
            <span class="ml-2 inline-block rounded-full bg-accent-100 px-2.5 py-0.5 font-ui text-xs font-medium text-accent-800">
              <%= t("authors.friends_badge") %>
            </span>
          <% end %>
        </p>
        <% if @author.bio.present? %>
          <p class="font-reading text-lg leading-relaxed text-pretty text-surface-700">
            <%= @author.bio %>
          </p>
        <% end %>
      </div>
    </div>

    <section class="border-t border-surface-200 pt-8" aria-labelledby="profile-stats">
      <h2 id="profile-stats" class="font-ui text-xs font-semibold uppercase tracking-[0.14em] text-accent-700">
        <%= t("authors.stats_heading") %>
      </h2>
      <% if is_owner %>
        <p class="mt-2 font-reading text-base leading-relaxed text-surface-600">
          <%= t("authors.stats_summary",
                total: @note_stats[:total],
                public: @note_stats[:public],
                private: @note_stats[:private]) %>
        </p>
      <% end %>
      <dl class="mt-5 grid gap-x-6 gap-y-5 <%= is_owner ? 'grid-cols-2 max-w-md' : 'grid-cols-1 max-w-[12rem]' %>">
        <% stats.each do |label, count| %>
          <div class="space-y-1">
            <dt class="font-ui text-xs font-medium uppercase tracking-wide text-surface-500"><%= label %></dt>
            <dd class="font-ui text-3xl font-semibold tabular-nums tracking-tight text-surface-900"><%= count %></dd>
          </div>
        <% end %>
      </dl>
    </section>
  </header>

  <section class="space-y-6 border-t border-surface-200 pt-10" aria-labelledby="profile-notes">
    <h2 id="profile-notes" class="font-ui text-sm font-semibold uppercase tracking-wide text-surface-500">
      <%= t("authors.public_notes_heading") %>
    </h2>

    <% if @notes.any? %>
      <ul class="divide-y divide-surface-200">
        <% @notes.each do |note| %>
          <li class="py-6 first:pt-0">
            <div class="flex items-start gap-3">
              <span class="mt-1.5 h-3 w-3 shrink-0 rounded-full note-marker-swatch-<%= note.color %>" aria-hidden="true"></span>
              <div class="min-w-0 flex-1">
                <% if note.highlights.any? %>
                  <p class="font-ui text-xs uppercase tracking-widest text-surface-500">
                    <%= osis_citation(note.highlights.first.osis_ref) %>
                    <% if note.label.present? %>
                      <span aria-hidden="true"> · </span>
                      <span class="normal-case tracking-normal text-surface-600"><%= note.label %></span>
                    <% end %>
                  </p>
                <% end %>
                <div class="mt-2 trix-content font-reading text-surface-900">
                  <%= note.body %>
                </div>
                <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 font-ui text-xs text-surface-500">
                  <span><%= l(note.updated_at, format: :long) %></span>
                  <%= link_to t("authors.view_and_comment", count: note.comments.size), note_path(note),
                              class: "font-medium text-accent-700 transition-colors hover:text-accent-800" %>
                  <% if note.upvote_count.positive? %>
                    <span><%= t("authors.likes", count: note.upvote_count) %></span>
                  <% end %>
                </div>
              </div>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="font-reading text-surface-600">
        <%= t("authors.no_public_notes") %>
      </p>
    <% end %>
  </section>
</article>
