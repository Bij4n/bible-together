<% content_for :title, @author.author_name %>

<article class="mx-auto max-w-3xl space-y-8">
  <header class="border-b border-surface-200 pb-6">
    <p class="font-ui text-xs font-medium uppercase tracking-wider text-surface-500">
      <%= t("authors.member_since", year: @author.created_at.year) %>
    </p>
    <div class="mt-2 flex flex-wrap items-center justify-between gap-4">
      <h1 class="font-ui text-4xl font-semibold tracking-tight text-surface-900 sm:text-5xl">
        <%= @author.author_name %>
      </h1>
      <% if user_signed_in? && current_user != @author %>
        <% if current_user.following?(@author) %>
          <%= button_to t("authors.unfollow"), author_follow_path(@author), method: :delete,
                        class: "rounded-full border border-surface-300 px-5 py-2 font-ui text-sm font-medium text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900" %>
        <% else %>
          <%= button_to t("authors.follow"), author_follow_path(@author), method: :post,
                        class: "rounded-full bg-accent-700 px-5 py-2 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800" %>
        <% end %>
      <% end %>
    </div>
    <p class="mt-3 font-ui text-sm text-surface-600">
      <%= t("authors.followers", count: @author.followers.count) %>
      <span aria-hidden="true">·</span>
      <%= t("authors.following_count", count: @author.following.count) %>
      <% if user_signed_in? && current_user != @author && current_user.friends_with?(@author) %>
        <span class="ml-2 inline-block rounded-full bg-accent-100 px-2.5 py-0.5 font-ui text-xs font-medium text-accent-800">
          <%= t("authors.friends_badge") %>
        </span>
      <% end %>
    </p>
    <% if @author.bio.present? %>
      <p class="mt-3 max-w-2xl font-reading text-surface-700">
        <%= @author.bio %>
      </p>
    <% end %>
  </header>

  <section>
    <h2 class="mb-4 font-ui text-lg font-semibold text-surface-900">
      <%= t("authors.public_notes_heading") %>
    </h2>

    <% if @notes.any? %>
      <ul class="space-y-3">
        <% @notes.each do |note| %>
          <li class="rounded-2xl border border-surface-200 bg-surface-50 p-5 sm:p-6">
            <% if note.highlights.any? %>
              <p class="font-ui text-xs uppercase tracking-widest text-surface-500">
                <%= note.highlights.first.osis_ref %>
              </p>
            <% end %>
            <div class="mt-2 trix-content font-reading text-surface-900">
              <%= note.body %>
            </div>
            <div class="mt-3 flex flex-wrap items-center gap-x-3 gap-y-1 font-ui text-xs text-surface-500">
              <span class="text-surface-400"><%= l(note.updated_at, format: :long) %></span>
              <%= link_to t("authors.view_and_comment", count: note.comments.size), note_path(note),
                          class: "font-medium text-accent-700 transition-colors hover:text-accent-800" %>
              <% if note.upvote_count.positive? %>
                <span><%= t("authors.likes", count: note.upvote_count) %></span>
              <% end %>
            </div>
          </li>
        <% end %>
      </ul>
    <% else %>
      <div class="rounded-2xl border border-surface-200 bg-surface-100/60 px-8 py-12 text-center">
        <p class="font-ui text-sm text-surface-600">
          <%= t("authors.no_public_notes") %>
        </p>
      </div>
    <% end %>
  </section>
</article>
