<% content_for :title, @group.name %>
<% is_owner = @group.owner_id == current_user.id %>
<%
  primary_btn   = "rounded-full bg-accent-700 px-5 py-2 font-ui text-sm font-medium text-surface-50 transition-colors hover:bg-accent-800"
  secondary_btn = "rounded-full border border-surface-300 px-5 py-2 font-ui text-sm font-medium text-surface-700 transition-colors hover:bg-surface-100 hover:text-surface-900"
  danger_btn    = "rounded-md border border-red-500/40 bg-transparent px-4 py-2 font-ui text-sm font-medium text-red-700 transition-colors hover:bg-red-500 hover:text-surface-50"
  danger_sm_btn = "rounded-md border border-red-500/40 bg-transparent px-2.5 py-1 font-ui text-xs font-medium text-red-700 transition-colors hover:bg-red-500 hover:text-surface-50"
  input_classes = "w-full rounded-md border border-surface-300 bg-surface-50 px-3 py-2 font-ui text-sm text-surface-900 transition-colors placeholder:text-surface-500 focus:border-accent-700 focus:outline-none focus:ring-2 focus:ring-accent-700/20"
  reading_path = group_bible_chapter_path(@group,
                                          translation: @reading_together[:translation],
                                          book: @reading_together[:book],
                                          chapter: @reading_together[:chapter])
%>

<article class="mx-auto max-w-3xl space-y-8">
  <header class="space-y-2 border-b border-surface-200 pb-6">
    <p class="font-ui text-xs font-medium uppercase tracking-wider text-surface-500">
      <%= t("groups.privacy.#{@group.privacy}") %> · <%= t("groups.member_count", count: @memberships.size) %>
    </p>
    <h1 class="font-ui text-4xl font-semibold tracking-tight text-surface-900 sm:text-5xl">
      <%= @group.name %>
    </h1>
    <% if @group.description.present? %>
      <p class="font-reading text-surface-700">
        <%= @group.description %>
      </p>
    <% end %>
  </header>

  <section class="rounded-2xl border border-surface-200 bg-surface-50 p-5 sm:p-6">
    <h2 class="font-ui text-lg font-semibold tracking-tight text-surface-900">
      <%= t("groups.reading_together") %>
    </h2>
    <p class="mt-1 font-ui text-sm text-surface-600">
      <%= t("groups.reading_together_intro") %>
    </p>
    <%= link_to t("groups.open_study_bible"), reading_path, class: "#{primary_btn} mt-4 inline-block" %>
  </section>

  <section class="space-y-4">
    <h2 class="font-ui text-lg font-semibold tracking-tight text-surface-900">
      <%= t("groups.member_notes") %>
    </h2>
    <% if @member_notes.any? %>
      <ul class="space-y-4">
        <% @member_notes.each do |note| %>
          <% first_highlight = note.highlights.first %>
          <% quoted_verse = first_highlight&.affected_verses&.first %>
          <li class="rounded-2xl border border-surface-200 bg-surface-50 p-5 sm:p-6">
            <% if quoted_verse %>
              <blockquote class="border-l-2 border-accent-700/30 pl-4 font-reading text-base leading-relaxed text-surface-700">
                <%= quoted_verse.body_text.truncate(180) %>
              </blockquote>
              <p class="mt-2 font-ui text-xs font-medium uppercase tracking-wider text-surface-500">
                <%= osis_citation(first_highlight.osis_ref) %>
              </p>
            <% end %>
            <div class="mt-3 line-clamp-4 font-reading text-surface-900">
              <%= note.body.to_plain_text.truncate(280) %>
            </div>
            <footer class="mt-4 flex flex-wrap items-center gap-x-4 gap-y-1 font-ui text-xs text-surface-500">
              <span class="font-medium text-surface-700"><%= note.user.author_name %></span>
              <% if first_highlight %>
                <% ref_parts = first_highlight.osis_ref.split(".") %>
                <% if ref_parts.size >= 4 %>
                  <%= link_to t("groups.read_in_context"),
                              group_bible_chapter_path(@group,
                                                       translation: ref_parts[1].downcase,
                                                       book: ref_parts[2].downcase,
                                                       chapter: ref_parts[3].to_i),
                              class: "underline underline-offset-2 transition-colors hover:text-accent-700" %>
                <% end %>
              <% end %>
            </footer>
          </li>
        <% end %>
      </ul>
    <% else %>
      <p class="font-ui text-sm text-surface-600">
        <%= t("groups.member_notes_empty") %>
      </p>
    <% end %>
  </section>

  <div class="flex flex-wrap items-center gap-3">
    <% if is_owner %>
      <%= link_to t("groups.edit"), edit_group_path(@group), class: secondary_btn %>
      <%= button_to t("groups.destroy"),
                    group_path(@group),
                    method: :delete,
                    form_class: "inline",
                    data: { turbo_confirm: t("groups.destroy") + "?" },
                    class: danger_btn %>
    <% else %>
      <%= button_to t("groups.leave"),
                    leave_group_path(@group),
                    method: :delete,
                    form_class: "inline",
                    data: { turbo_confirm: t("groups.leave") + "?" },
                    class: secondary_btn %>
    <% end %>
  </div>

  <% if is_owner && @group.invitation_code.present? %>
    <section class="rounded-2xl border border-surface-200 bg-surface-50 p-5 sm:p-6">
      <h2 class="font-ui text-xs font-semibold uppercase tracking-wider text-surface-500">
        <%= t("groups.invitation_code") %>
      </h2>
      <p class="mt-2 font-mono text-2xl text-surface-900">
        <%= @group.invitation_code %>
      </p>
    </section>
  <% end %>

  <section class="rounded-2xl border border-surface-200 bg-surface-50 p-5 sm:p-6">
    <h2 class="font-ui text-lg font-semibold tracking-tight text-surface-900">
      <%= t("groups.members") %>
    </h2>
    <ul class="mt-3 space-y-2">
      <% @memberships.each do |m| %>
        <li class="flex items-center justify-between rounded-md border border-surface-200 bg-surface-100 px-4 py-2">
          <span class="font-ui text-sm text-surface-900">
            <%= m.user.author_name %>
          </span>
          <div class="flex items-center gap-3">
            <span class="font-ui text-xs uppercase tracking-wider text-surface-500">
              <%= t("groups.role.#{m.role}") %>
            </span>
            <% if is_owner && m.user_id != current_user.id %>
              <%= button_to t("memberships.remove"),
                            group_membership_path(@group, m),
                            method: :delete,
                            form_class: "inline",
                            data: { turbo_confirm: t("memberships.remove") + "?" },
                            class: danger_sm_btn %>
            <% end %>
          </div>
        </li>
      <% end %>
    </ul>

    <% if is_owner %>
      <%= form_with url: group_invitations_path(@group), method: :post, scope: :group_invitation, class: "mt-4 flex gap-2" do |f| %>
        <%= f.email_field :email,
                          required: true,
                          placeholder: t("memberships.email_placeholder"),
                          class: input_classes %>
        <%= f.submit t("group_invitations.invite_button"), class: primary_btn %>
      <% end %>
    <% end %>
  </section>

  <% if is_owner && @pending_invitations.any? %>
    <section class="rounded-2xl border border-surface-200 bg-surface-50 p-5 sm:p-6">
      <h2 class="font-ui text-lg font-semibold tracking-tight text-surface-900">
        <%= t("group_invitations.pending_heading") %>
      </h2>
      <p class="mt-1 font-ui text-sm text-surface-600">
        <%= t("group_invitations.pending_intro") %>
      </p>
      <ul class="mt-4 space-y-2">
        <% @pending_invitations.each do |invitation| %>
          <li class="flex items-center justify-between gap-3 rounded-md border border-surface-200 bg-surface-100 px-4 py-2">
            <span class="font-ui text-sm text-surface-900">
              <%= invitation.email %>
            </span>
            <%= button_to t("group_invitations.cancel"),
                          group_invitation_path(@group, invitation),
                          method: :delete,
                          form_class: "inline",
                          data: { turbo_confirm: t("group_invitations.cancel_confirm", email: invitation.email) },
                          class: danger_sm_btn %>
          </li>
        <% end %>
      </ul>
    </section>
  <% end %>
</article>
