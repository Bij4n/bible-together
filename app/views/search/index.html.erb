<% content_for :title, t("search.title") %>

<article class="mx-auto max-w-3xl space-y-8">
  <header class="space-y-1">
    <h1 class="font-display text-4xl font-semibold uppercase tracking-[0.1em] text-walnut-900 dark:text-amber-200">
      <%= t("search.title") %>
    </h1>
    <p class="font-serif italic text-walnut-700 dark:text-amber-300">
      <%= t("search.subtitle") %>
    </p>
  </header>

  <%= form_with url: search_path, method: :get, class: "space-y-3" do |f| %>
    <div class="flex gap-2">
      <%= f.text_field :q,
                       value: @query,
                       placeholder: t("search.input_placeholder"),
                       autofocus: true,
                       autocomplete: "off",
                       class: "flex-1 rounded border border-walnut-900/25 bg-parchment-50 px-3 py-2 font-serif text-walnut-900 focus:border-walnut-900 focus:outline-none dark:border-gilt-500/40 dark:bg-walnut-900 dark:text-amber-200" %>
      <%= f.submit t("search.submit"),
                   class: "rounded bg-walnut-900 px-4 py-2 font-display text-sm font-medium uppercase tracking-wider text-parchment-100 hover:bg-walnut-800 dark:bg-amber-200 dark:text-walnut-900" %>
    </div>

    <fieldset class="flex items-center gap-4 font-serif text-sm">
      <legend class="sr-only"><%= t("search.modes.keyword") %></legend>
      <% SearchController::MODES.each do |mode| %>
        <label class="flex items-center gap-1">
          <%= f.radio_button :mode, mode, checked: @mode == mode %>
          <%= t("search.modes.#{mode}") %>
        </label>
      <% end %>
    </fieldset>

    <fieldset class="flex items-center gap-4 font-serif text-sm">
      <legend class="sr-only"><%= t("search.filters.all") %></legend>
      <% SearchService::VALID_SCOPES.each do |scope| %>
        <label class="flex items-center gap-1">
          <%= f.radio_button :scope, scope, checked: @scope == scope %>
          <%= t("search.filters.#{scope}") %>
        </label>
      <% end %>
    </fieldset>

    <% if Translation.count > 1 %>
      <fieldset class="flex items-center gap-4 font-serif text-sm">
        <legend class="sr-only"><%= t("search.translations.all") %></legend>
        <% SearchService::VALID_TRANSLATIONS.each do |ts| %>
          <label class="flex items-center gap-1">
            <%= f.radio_button :translations, ts, checked: @translations == ts %>
            <%= t("search.translations.#{ts}") %>
          </label>
        <% end %>
      </fieldset>
      <%= f.hidden_field :translation_code, value: @translation_code %>
    <% end %>

    <% if @mode == "semantic" %>
      <p class="font-serif text-xs italic text-walnut-700/70 dark:text-amber-200/60">
        <%= t("search.semantic_explanation") %>
      </p>
    <% end %>
  <% end %>

  <% if @query.present? %>
    <% if @results[:semantic_fallback] %>
      <p class="rounded border border-rubric-500/30 bg-rubric-500/10 px-4 py-3 font-serif text-sm text-walnut-900 dark:border-gilt-500/40 dark:bg-walnut-800 dark:text-amber-200">
        <%= t("search.semantic_unavailable") %>
      </p>
    <% end %>

    <% if @results[:notes_scope_requested] %>
      <p class="rounded border border-walnut-900/15 bg-parchment-50 px-4 py-3 font-serif text-sm text-walnut-700 dark:border-gilt-500/30 dark:bg-walnut-800 dark:text-amber-300">
        <%= t("search.semantic_notes_pending") %>
      </p>
    <% end %>

    <%= render partial: "results", locals: { results: @results, query: @query, scope: @scope } %>
  <% else %>
    <section class="space-y-3">
      <p class="font-serif italic text-walnut-700 dark:text-amber-300">
        <%= t("search.empty_hint") %>
      </p>
      <div>
        <h2 class="font-display text-sm uppercase tracking-wider text-walnut-900/70 dark:text-amber-200/70">
          <%= t("search.suggestions_heading") %>
        </h2>
        <div class="mt-2 flex flex-wrap gap-2">
          <% t("search.suggestions").each do |term| %>
            <%= link_to term, search_path(q: term),
                        class: "rounded border border-walnut-900/25 px-3 py-1 text-sm font-serif text-walnut-900 hover:bg-walnut-900 hover:text-parchment-100 dark:border-gilt-500/40 dark:text-amber-200" %>
          <% end %>
        </div>
      </div>
    </section>
  <% end %>
</article>
